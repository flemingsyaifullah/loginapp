{
  "name": "backend-repo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
  "dev": "ts-node-dev --respawn ./core/app.ts",
  "copyfirebaseaccount": "copy config\\firebaseServiceAccount.json dist\\config\\",
  "functions:build": "cd functions && tsc",
  "build": "tsc && npm run copyfirebaseaccount && npm run functions:build",
  "emulators": "npm run build && npm run copyfirebaseaccount && npm run functions:build && set DOTENV_CONFIG_PATH=.env && npx --node-options=\"-r dotenv/config\" firebase emulators:start --only functions"
  },
